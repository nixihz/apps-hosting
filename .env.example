# Runtime
APPS_PORT=4173
APPS_DATA_DIR=.apps-data
APPS_ENV=dev

# Security
# Generate strong values for production. Do not commit real secrets.
APPS_SECRET_KEY=
APPS_2FA_SECRET=
APPS_ADMIN_TOKEN=
APPS_GOOGLE_ANALYTICS_ID=

# Optional OIDC
APPS_OIDC_ISSUER=
APPS_OIDC_CLIENT_ID=

# Optional CLI tarball download directory
APPS_CLI_DOWNLOAD_DIR=dist/npm
